{
  "manifest_version": 3,
  "name": "阅读剪藏 · 划线批注",
  "version": "0.1.0",
  "description": "一边读文章一边划线、写批注。按 DOM 智能抓取正文，连同批注一起以 Markdown 导出或发送到 Notion。",
  "author": "Roxane <Alondite04@gmail.com>",
  "homepage_url": "https://github.com/Rosalion/readnotes-clipping",
  "minimum_chrome_version": "114",
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": ["https://api.notion.com/*"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "阅读剪藏 · 划线批注（点击开关侧边栏）",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "lib/Readability.js",
        "content/anchor.js",
        "content/highlighter.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}
